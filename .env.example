# Set ONE of these (checked in this order):
# OPENROUTER_API_KEY=your-key    # https://openrouter.ai/keys
# OPENAI_API_KEY=your-key        # https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY=your-key     # https://console.anthropic.com/settings/keys
# GEMINI_API_KEY=your-key        # https://aistudio.google.com/apikey
# DEEPSEEK_API_KEY=your-key      # https://platform.deepseek.com/api_keys
# GROQ_API_KEY=your-key          # https://console.groq.com/keys
# (or run Ollama locally, or have the Claude Code CLI installed on PATH)
OPENROUTER_API_KEY=your-api-key-here

# Logging level (optional, default: warn)
# Options: trace, debug, info, warn, error
RUST_LOG=warn
